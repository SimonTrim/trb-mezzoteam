PORT=3001
NODE_ENV=development

# Mode démo : données fictives sans clé API Mezzoteam (true en développement)
USE_MOCK_MEZZOTEAM=true

# Mode démo : données fictives Trimble Connect (true en développement, sans jeton TC)
USE_MOCK_TRIMBLE=true
# Base REST Trimble Connect (laisser vide pour déduire de la région du projet)
# TRIMBLE_API_BASE=https://app.connect.trimble.com/tc/api/2.0

# AppXchange / Trimble Identity OAuth2
TRIMBLE_CLIENT_ID=
TRIMBLE_CLIENT_SECRET=
TRIMBLE_REDIRECT_URI=http://localhost:3001/api/auth/callback
TRIMBLE_AUTH_URL=https://id.trimble.com/oauth/authorize
TRIMBLE_TOKEN_URL=https://id.trimble.com/oauth/token
TRIMBLE_SCOPE=openid

# Session
SESSION_SECRET=change-me-in-production

# Mezzoteam API — https://api.mezzoteam.com/swagger/index.html
MEZZOTEAM_API_BASE=https://api.mezzoteam.com
MEZZOTEAM_API_VERSION=3.4

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
